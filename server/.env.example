# 后端环境变量配置
# 复制此文件为 .env 并填写实际值

NODE_ENV=development
PORT=3002
API_KEY=your_deepseek_api_key_here
API_MODEL=deepseek-chat
API_BASE_URL=https://api.deepseek.com

# ===========================================
# CORS 配置（生产环境必须配置）
# ===========================================
# 开发环境
ALLOWED_ORIGINS=http://localhost:5173

# 生产环境（Vercel 前端 + Railway 本地开发）
# ALLOWED_ORIGINS=http://localhost:5173,https://ai-haigui-game-c5n4.vercel.app
